    "lucide-react": "^0.525.0",
    "pino": "^9.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@cloudflare/vite-plugin": "1.17.1",
    "@cloudflare/workers-types": "^4.20250424.0",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8",
    "vite": "^6.3.1",
    "wrangler": "^4.39.0"
